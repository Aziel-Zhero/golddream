
{
  "entities": {
    "Usuario": {
      "title": "Usuario",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telefone": { "type": "string" },
        "endereco": {
          "type": "object",
          "properties": {
            "rua": { "type": "string" },
            "bairro": { "type": "string" },
            "cidade": { "type": "string" },
            "cep": { "type": "string" }
          }
        },
        "papel": { "type": "string", "enum": ["cliente", "administrador"] },
        "dataCriacao": { "type": "string", "format": "date-time" }
      }
    },
    "ConfiguracaoSite": {
      "title": "ConfiguracaoSite",
      "type": "object",
      "properties": {
        "heroBadge": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroDescription": { "type": "string" },
        "heroImage": { "type": "string" },
        "telegramLink": { "type": "string" },
        "b1_title": { "type": "string" },
        "b1_sub": { "type": "string" },
        "b1_icon": { "type": "string" },
        "b2_title": { "type": "string" },
        "b2_sub": { "type": "string" },
        "b2_icon": { "type": "string" },
        "b3_title": { "type": "string" },
        "b3_sub": { "type": "string" },
        "b3_icon": { "type": "string" },
        "b4_title": { "type": "string" },
        "b4_sub": { "type": "string" },
        "b4_icon": { "type": "string" }
      }
    },
    "Frete": {
      "title": "Frete",
      "type": "object",
      "properties": {
        "cidade": { "type": "string" },
        "bairro": { "type": "string" },
        "valor": { "type": "number" }
      }
    },
    "Cupom": {
      "title": "Cupom",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "desconto": { "type": "number", "description": "Valor em porcentagem" },
        "expira": { "type": "boolean" },
        "dataExpiracao": { "type": "string", "format": "date" }
      }
    }
  },
  "firestore": {
    "structure": [
      { "path": "/usuarios/{uid}", "definition": { "entityName": "Usuario", "schema": { "$ref": "#/backend/entities/Usuario" } } },
      { "path": "/configuracoes/geral", "definition": { "entityName": "ConfiguracaoSite", "schema": { "$ref": "#/backend/entities/ConfiguracaoSite" } } },
      { "path": "/fretes/{freteId}", "definition": { "entityName": "Frete", "schema": { "$ref": "#/backend/entities/Frete" } } },
      { "path": "/cupons/{cupomId}", "definition": { "entityName": "Cupom", "schema": { "$ref": "#/backend/entities/Cupom" } } },
      { "path": "/produtos/{produtoId}", "definition": { "entityName": "Produto", "schema": { "$ref": "#/backend/entities/Produto" } } }
    ]
  }
}
