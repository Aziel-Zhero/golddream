
{
  "entities": {
    "Usuario": {
      "title": "Usuario",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telefone": { "type": "string" },
        "emailVerificado": { "type": "boolean" },
        "endereco": {
          "type": "object",
          "properties": {
            "rua": { "type": "string" },
            "bairro": { "type": "string" },
            "cidade": { "type": "string" },
            "cep": { "type": "string" },
            "numero": { "type": "string" }
          }
        },
        "papel": { "type": "string", "enum": ["cliente", "administrador", "admin"] },
        "dataCriacao": { "type": "string", "format": "date-time" }
      }
    },
    "Produto": {
      "title": "Produto",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "preco": { "type": "number" },
        "descricao": { "type": "string" },
        "categoriaId": { "type": "string" },
        "tamanhosDisponiveis": { "type": "array", "items": { "type": "string" } },
        "variacoes": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "cor": { "type": "string" },
              "estoque": { "type": "number" },
              "imagens": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "estoque": { "type": "number", "description": "Total acumulado de todas as variações" },
        "isFeatured": { "type": "boolean" },
        "isNovidade": { "type": "boolean", "description": "Ativa selo Novidade piscante verde" },
        "isLancamento": { "type": "boolean", "description": "Ativa selo Lançamento amarelo" },
        "isUltimasPecas": { "type": "boolean", "description": "Ativa selo Últimas Peças vermelho" },
        "dataCriacao": { "type": "string", "format": "date-time" }
      }
    },
    "Pedido": {
      "title": "Pedido",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "usuarioId": { "type": "string" },
        "clienteNome": { "type": "string" },
        "itens": { "type": "array" },
        "subtotal": { "type": "number" },
        "frete": { "type": "number" },
        "desconto": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pendente", "confirmado", "em_separacao", "entregue", "cancelado"] },
        "dataCriacao": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "structure": [
      { "path": "/usuarios/{uid}", "definition": { "entityName": "Usuario", "schema": { "$ref": "#/backend/entities/Usuario" } } },
      { "path": "/configuracoes/geral", "definition": { "entityName": "ConfiguracaoSite", "schema": { "$ref": "#/backend/entities/ConfiguracaoSite" } } },
      { "path": "/configuracoes/telegram", "definition": { "entityName": "ConfiguracaoTelegram", "schema": { "$ref": "#/backend/entities/ConfiguracaoTelegram" } } },
      { "path": "/fretes/{freteId}", "definition": { "entityName": "Frete", "schema": { "$ref": "#/backend/entities/Frete" } } },
      { "path": "/cupons/{cupomId}", "definition": { "entityName": "Cupom", "schema": { "$ref": "#/backend/entities/Cupom" } } },
      { "path": "/produtos/{produtoId}", "definition": { "entityName": "Produto", "schema": { "$ref": "#/backend/entities/Produto" } } },
      { "path": "/pedidos/{pedidoId}", "definition": { "entityName": "Pedido", "schema": { "$ref": "#/backend/entities/Pedido" } } },
      { "path": "/suporte/{slug}", "definition": { "entityName": "Suporte", "schema": { "$ref": "#/backend/entities/Suporte" } } }
    ]
  }
}
