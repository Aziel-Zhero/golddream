
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Dados do usuário na plataforma.",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telefone": { "type": "string" },
        "papel": { "type": "string", "enum": ["cliente", "admin"] },
        "dataCriacao": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "nome", "email", "papel", "dataCriacao"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "Produto do catálogo.",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "preco": { "type": "number" },
        "descricao": { "type": "string" },
        "categoriaId": { "type": "string" },
        "estoque": { "type": "number" },
        "averageRating": { "type": "number" },
        "reviewCount": { "type": "number" }
      }
    },
    "Review": {
      "title": "Review",
      "type": "object",
      "description": "Avaliação de um produto por um usuário.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "productId": { "type": "string" },
        "rating": { "type": "number", "minimum": 1, "maximum": 5 },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "productId", "rating", "createdAt"]
    },
    "EligibleReview": {
      "title": "EligibleReview",
      "type": "object",
      "description": "Item comprado e entregue que pode ser avaliado.",
      "properties": {
        "productId": { "type": "string" },
        "orderId": { "type": "string" },
        "productName": { "type": "string" },
        "deliveryDate": { "type": "string", "format": "date-time" },
        "expiresAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password"]
  },
  "firestore": {
    "/usuarios/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Perfis de usuários."
    },
    "/produtos/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Catálogo de produtos."
    },
    "/produtos/{productId}/avaliacoes/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Avaliações públicas do produto."
    },
    "/usuarios/{userId}/itens_elegiveis_avaliacao/{itemId}": {
      "schema": { "$ref": "#/entities/EligibleReview" },
      "description": "Itens que o usuário pode avaliar após entrega."
    },
    "/usuarios/{userId}/produtos_avaliados/{productId}": {
      "schema": { "type": "object" },
      "description": "Flag para evitar múltiplas avaliações do mesmo produto."
    },
    "/pedidos/{orderId}": {
      "schema": { "type": "object" },
      "description": "Histórico de pedidos."
    }
  }
}
