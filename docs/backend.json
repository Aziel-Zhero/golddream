
{
  "entities": {
    "Usuario": {
      "title": "Usuario",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "nome": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "telefone": { "type": "string" },
        "endereco": {
          "type": "object",
          "properties": {
            "rua": { "type": "string" },
            "bairro": { "type": "string" },
            "cidade": { "type": "string" },
            "cep": { "type": "string" },
            "numero": { "type": "string" }
          }
        },
        "papel": { "type": "string", "enum": ["cliente", "administrador"] },
        "dataCriacao": { "type": "string", "format": "date-time" }
      }
    },
    "Pedido": {
      "title": "Pedido",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "usuarioId": { "type": "string" },
        "clienteNome": { "type": "string" },
        "itens": { "type": "array" },
        "subtotal": { "type": "number" },
        "frete": { "type": "number" },
        "desconto": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pendente", "entregue", "cancelado"] },
        "dataCriacao": { "type": "string", "format": "date-time" }
      }
    },
    "ConfiguracaoTelegram": {
      "title": "ConfiguracaoTelegram",
      "type": "object",
      "properties": {
        "botToken": { "type": "string" },
        "chatId": { "type": "string" },
        "testChatId": { "type": "string" },
        "headerImage": { "type": "string" },
        "isActive": { "type": "boolean" }
      }
    },
    "ConfiguracaoSite": {
      "title": "ConfiguracaoSite",
      "type": "object",
      "properties": {
        "heroBadge": { "type": "string" },
        "heroTitle": { "type": "string" },
        "heroDescription": { "type": "string" },
        "heroImage": { "type": "string" },
        "telegramLink": { "type": "string" },
        "b1_title": { "type": "string" },
        "b1_sub": { "type": "string" },
        "b1_icon": { "type": "string" },
        "b2_title": { "type": "string" },
        "b2_sub": { "type": "string" },
        "b2_icon": { "type": "string" },
        "b3_title": { "type": "string" },
        "b3_sub": { "type": "string" },
        "b3_icon": { "type": "string" },
        "b4_title": { "type": "string" },
        "b4_sub": { "type": "string" },
        "b4_icon": { "type": "string" }
      }
    },
    "Frete": {
      "title": "Frete",
      "type": "object",
      "properties": {
        "cidade": { "type": "string" },
        "bairro": { "type": "string" },
        "valor": { "type": "number" }
      }
    },
    "Cupom": {
      "title": "Cupom",
      "type": "object",
      "properties": {
        "codigo": { "type": "string" },
        "desconto": { "type": "number", "description": "Valor em porcentagem" },
        "expira": { "type": "boolean" },
        "dataExpiracao": { "type": "string", "format": "date" }
      }
    },
    "Suporte": {
      "title": "Suporte",
      "type": "object",
      "properties": {
        "titulo": { "type": "string" },
        "conteudo": { "type": "string" },
        "slug": { "type": "string" }
      }
    }
  },
  "firestore": {
    "structure": [
      { "path": "/usuarios/{uid}", "definition": { "entityName": "Usuario", "schema": { "$ref": "#/backend/entities/Usuario" } } },
      { "path": "/configuracoes/geral", "definition": { "entityName": "ConfiguracaoSite", "schema": { "$ref": "#/backend/entities/ConfiguracaoSite" } } },
      { "path": "/configuracoes/telegram", "definition": { "entityName": "ConfiguracaoTelegram", "schema": { "$ref": "#/backend/entities/ConfiguracaoTelegram" } } },
      { "path": "/fretes/{freteId}", "definition": { "entityName": "Frete", "schema": { "$ref": "#/backend/entities/Frete" } } },
      { "path": "/cupons/{cupomId}", "definition": { "entityName": "Cupom", "schema": { "$ref": "#/backend/entities/Cupom" } } },
      { "path": "/produtos/{produtoId}", "definition": { "entityName": "Produto", "schema": { "$ref": "#/backend/entities/Produto" } } },
      { "path": "/pedidos/{pedidoId}", "definition": { "entityName": "Pedido", "schema": { "$ref": "#/backend/entities/Pedido" } } },
      { "path": "/suporte/{slug}", "definition": { "entityName": "Suporte", "schema": { "$ref": "#/backend/entities/Suporte" } } }
    ]
  }
}
