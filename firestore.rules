
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é admin sem causar recursão
    // 1. Checa a coleção dedicada de papéis (mais rápido e seguro)
    // 2. Ou checa o campo 'papel' no documento do usuário (fallback)
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'])
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE COLEÇÃO ---

    match /roles_administrador/{usuarioId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /usuarios/{usuarioId} {
      allow create: if isSignedIn() && request.auth.uid == usuarioId;
      // get: permite ao dono ou admin
      allow get: if isOwner(usuarioId) || exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid));
      // list/update: permite ao dono ou admin
      allow list, update: if isOwner(usuarioId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Qualquer um pode criar um pedido (checkout aberto)
      allow create: if true;
      
      // Listagem: Cliente vê apenas os seus. Admin vê todos.
      allow list: if isAdmin() || (isSignedIn() && request.query.limit <= 100 && resource.data.usuarioId == request.auth.uid);
      
      // Get: Cliente vê o seu. Admin vê qualquer um.
      allow get: if isAdmin() || (isSignedIn() && resource.data.usuarioId == request.auth.uid);
      
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
