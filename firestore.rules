
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é administrador buscando o documento no banco
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{uid} {
      // Regra fundamental: O dono SEMPRE pode ler seu perfil (evita recursão)
      allow read: if isSignedIn() && request.auth.uid == uid;
      
      // Administradores podem ler qualquer perfil
      allow read: if isSignedIn() && isAdmin();
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow delete: if isSignedIn() && isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Qualquer logado pode criar seu pedido
      allow create: if isSignedIn() && request.resource.data.usuarioId == request.auth.uid;
      
      // Leitura e Listagem: Permitido se for o dono do pedido (usuarioId) ou admin
      // Nota: O método list exige que a query do app tenha where('usuarioId', '==', uid)
      allow read, list: if isSignedIn() && (
        (resource != null && resource.data.usuarioId == request.auth.uid) || 
        isAdmin() ||
        (resource == null)
      );
      
      allow update, delete: if isSignedIn() && isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isSignedIn() && isAdmin();
    }
  }
}
