
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado tem papel de administrador.
    // Importante: Não chamamos esta função dentro da regra de leitura do próprio usuário para evitar recursão.
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{usuarioId} {
      // Regra crucial para evitar recursão: 
      // O usuário pode ler seu próprio documento SEMPRE se estiver logado e for o dono.
      // Se não for o dono, aí sim verificamos se é admin.
      allow read: if isSignedIn() && (request.auth.uid == usuarioId || (request.auth.uid != usuarioId && isAdmin()));
      allow list, update: if isSignedIn() && (request.auth.uid == usuarioId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == usuarioId;
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Qualquer um pode criar um pedido (checkout)
      allow create: if true;
      
      // Administradores veem tudo. Clientes veem apenas seus próprios pedidos.
      allow list: if isSignedIn() && (
        isAdmin() || 
        (request.query.limit <= 50 && request.query.filters.usuarioId == request.auth.uid)
      );
      
      allow get: if isSignedIn() && (
        isAdmin() || 
        (resource.data.usuarioId == request.auth.uid)
      );
      
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
