
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Gold Dream Multimarcas - Regras de Segurança
     * Versão: 1.3.0 - Resolução de recursão infinita e permissões de listagem
     */

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é admin. 
    // IMPORTANTE: Não chamamosisAdmin dentro das regras de /usuarios para evitar loop.
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'])
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE COLEÇÃO ---

    match /roles_administrador/{usuarioId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /usuarios/{usuarioId} {
      allow create: if isSignedIn() && request.auth.uid == usuarioId;
      // Removida a chamada isAdmin() aqui para evitar recursão
      allow get: if isOwner(usuarioId) || exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid));
      allow list, update: if isOwner(usuarioId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      // Correção na listagem: Permite ler se for admin ou se o filtro da query for o próprio usuarioId
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.usuarioId == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
