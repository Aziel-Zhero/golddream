
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado tem papel de administrador.
    // Usamos curto-circuito para evitar recursão infinita.
    function isAdmin() {
      let userDoc = get(/databases/$(database)/documents/usuarios/$(request.auth.uid));
      return isSignedIn() && (
        userDoc.data.papel == 'admin' || 
        userDoc.data.papel == 'administrador'
      );
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{usuarioId} {
      // O dono sempre pode ler e atualizar seu próprio documento.
      // Isso é crucial para que o isAdmin() consiga ler o documento do admin sem travar.
      allow read, update: if isSignedIn() && (request.auth.uid == usuarioId || isAdmin());
      allow create: if isSignedIn();
      allow list, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Criação aberta para processar o checkout
      allow create: if true;
      
      // Administradores veem tudo. Clientes veem apenas seus próprios pedidos.
      allow read, list: if isSignedIn() && (
        isAdmin() || 
        (resource.data.usuarioId == request.auth.uid)
      );
      
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
