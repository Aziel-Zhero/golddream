
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado tem papel de administrador.
    // Usamos uma leitura direta para evitar recursão em regras que também chamam isAdmin.
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{usuarioId} {
      // Regra robusta: O dono sempre lê, admin lê todos. 
      // Não usamos isAdmin() para o dono ler a si mesmo para evitar recursão infinita.
      allow read: if isSignedIn() && (request.auth.uid == usuarioId || (request.auth.uid != usuarioId && isAdmin()));
      allow list, update: if isSignedIn() && (request.auth.uid == usuarioId || isAdmin());
      allow create: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Qualquer um pode criar um pedido (checkout)
      allow create: if true;
      
      // Administradores veem tudo. Clientes veem apenas seus próprios pedidos.
      allow list: if isSignedIn() && (
        isAdmin() || 
        (resource.data.usuarioId == request.auth.uid)
      );
      
      allow get: if isSignedIn() && (
        isAdmin() || 
        (resource.data.usuarioId == request.auth.uid)
      );
      
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
