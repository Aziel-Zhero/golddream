
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Gold Dream Multimarcas - Regras de Segurança
     * Versão: 1.1.0 - Correção de recursão e permissões de pedidos
     */

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é admin via coleção dedicada ou campo no perfil.
    // IMPORTANTE: Para evitar recursão infinita, a regra de 'get' da coleção 'usuarios' 
    // para o próprio usuário não deve chamar isAdmin().
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid)) ||
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador']
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE COLEÇÃO ---

    match /roles_administrador/{usuarioId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /usuarios/{usuarioId} {
      allow create: if isSignedIn() && request.auth.uid == usuarioId;
      // allow get para o dono SEM isAdmin() evita recursão fatal quando isAdmin() chama get()
      allow get: if isOwner(usuarioId) || exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid));
      allow list, update: if isOwner(usuarioId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      // Permite que o dono veja seus próprios pedidos ou o admin veja tudo
      allow read: if isAdmin() || (isSignedIn() && resource.data.usuarioId == request.auth.uid);
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{produtoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{promocaoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
