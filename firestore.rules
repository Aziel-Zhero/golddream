
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Gold Dream Multimarcas - Regras de Segurança
     * Versão: 1.2.0 - Correção de robustez isAdmin e permissões de listagem
     */

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é admin via coleção dedicada ou campo no perfil.
    // Adicionado exists() antes do get() para evitar erro de execução se o doc não existir.
    function isAdmin() {
      return isSignedIn() && (
        exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid)) ||
        (exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'])
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE COLEÇÃO ---

    match /roles_administrador/{usuarioId} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }

    match /usuarios/{usuarioId} {
      allow create: if isSignedIn() && request.auth.uid == usuarioId;
      // Permite get para o dono ou admin. isOwner não chama isAdmin, evitando recursão.
      allow get: if isOwner(usuarioId) || exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid));
      allow list, update: if isOwner(usuarioId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      // Permite que o dono veja seus próprios pedidos ou o admin veja tudo.
      // Para listagem (list), o Firestore verifica se o filtro da query corresponde a esta regra.
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.usuarioId == request.auth.uid));
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{produtoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{promocaoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
