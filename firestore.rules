
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é admin acessando diretamente os dados sem chamar recursão
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador', 'admin_vogue'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{uid} {
      // O segredo para evitar recursão: se o UID for o do próprio usuário, permite ler direto.
      // Se for outro UID, verifica se quem está pedindo é admin consultando o perfil do pedinte.
      allow read: if isSignedIn() && (
        request.auth.uid == uid || 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador']
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      
      // Administradores veem tudo. Clientes veem apenas onde o usuarioId coincide.
      allow read, list: if isSignedIn() && (
        (request.auth.uid == resource.data.usuarioId) || 
        isAdmin()
      );
      
      allow update, delete: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
