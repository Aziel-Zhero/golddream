
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado tem papel administrativo
    // Importante: Esta função faz um 'get', que pode disparar regras de leitura.
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador', 'admin_vogue'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{uid} {
      // O curto-circuito (auth.uid == uid) é essencial para EVITAR RECURSÃO INFINITA
      // Se for o dono do perfil, ele lê sem chamar a função isAdmin()
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Qualquer usuário logado pode criar pedidos
      allow create: if isSignedIn() && request.resource.data.usuarioId == request.auth.uid;
      
      // Regra de leitura e listagem:
      // Admins podem ver tudo. Clientes podem ver apenas se o usuarioId coincidir.
      // O Firestore permite 'list' se a query do cliente tiver o filtro .where('usuarioId', '==', uid)
      allow read, list: if isSignedIn() && (
        isAdmin() || resource.data.usuarioId == request.auth.uid
      );
      
      allow update, delete: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
