
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Função central de admin - usa get() para verificar o campo 'papel' no documento do usuário
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{usuarioId} {
      // PERMITIR que o usuário leia seu próprio perfil SEM chamar isAdmin() para evitar recursão infinita
      // Se for o próprio dono do UID, permite. Se não for, verifica se quem está lendo é um administrador.
      allow read: if isSignedIn() && (
        request.auth.uid == usuarioId || 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador']
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == usuarioId || isAdmin());
      allow list, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Criar pedido é livre (ou pode restringir para isSignedIn() se desejar)
      allow create: if true;
      
      // Regra de leitura/listagem:
      // 1. Administradores podem ler tudo.
      // 2. Clientes podem ler apenas documentos onde o usuarioId coincide com seu UID.
      allow read, list: if isSignedIn() && (
        (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador']) || 
        (resource.data.usuarioId == request.auth.uid)
      );
      
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
