
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário tem um papel específico
    // IMPORTANTE: Esta função só deve ser chamada após garantir que não há recursão
    function hasRole(roles) {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in roles;
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{uid} {
      // PERMISSÃO CRÍTICA: Permite ler o próprio perfil sem chamar hasRole() para evitar recursão infinita
      allow read: if isSignedIn() && request.auth.uid == uid;
      
      // Permite que administradores leiam outros perfis
      allow read: if isSignedIn() && hasRole(['admin', 'administrador']);
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || hasRole(['admin', 'administrador']));
      allow list, delete: if isSignedIn() && hasRole(['admin', 'administrador']);
    }

    match /pedidos/{pedidoId} {
      // Qualquer usuário logado pode criar pedidos
      allow create: if isSignedIn();
      
      // Regra de leitura e listagem:
      // 1. O dono do pedido pode ler/listar seus próprios documentos (usuarioId deve bater com o UID)
      // 2. Administradores podem ler/listar tudo
      allow read, list: if isSignedIn() && (
        (resource != null && resource.data.usuarioId == request.auth.uid) ||
        hasRole(['admin', 'administrador']) ||
        (resource == null) // Permite que a query inicial de listagem seja avaliada
      );
      
      allow update, delete: if isSignedIn() && hasRole(['admin', 'administrador']);
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(['admin', 'administrador']);
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(['admin', 'administrador']);
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(['admin', 'administrador']);
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(['admin', 'administrador']);
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(['admin', 'administrador']);
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(['admin', 'administrador']);
    }
  }
}
