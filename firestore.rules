
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é admin. 
    // Usamos 'get' mas o match de usuarios garante o curto-circuito para o dono
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador', 'admin_vogue'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{uid} {
      // Dono lê e edita sempre. Admin lê e lista todos.
      // O curto-circuito (auth.uid == uid) evita a recursão no isAdmin()
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if isSignedIn();
      
      // Regra de listagem/leitura:
      // Admins podem tudo. Clientes podem ver se o usuarioId bater com o UID deles.
      // Firestore exige que queries filtrem por usuarioId para autorizar o 'list'.
      allow read, list: if isSignedIn() && (
        isAdmin() || (resource != null && resource.data.usuarioId == request.auth.uid)
      );
      
      allow update, delete: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
