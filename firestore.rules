
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Obtém o papel do usuário sem causar recursão
    function getUserRole() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel;
    }

    function isAdmin() {
      return isSignedIn() && (getUserRole() == "admin" || getUserRole() == "administrador");
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{uid} {
      // PERMISSÃO: O dono lê seu perfil primeiro para evitar recursão ao chamar isAdmin()
      allow read: if isSignedIn() && (request.auth.uid == uid || (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador']));
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Criar pedido é livre (ou isSignedIn()) para visitantes/clientes
      allow create: if true;
      
      // Regra de leitura/listagem:
      // 1. Administradores podem ler TUDO.
      // 2. Clientes podem ler apenas documentos onde o usuarioId coincide com seu UID.
      allow read, list: if isSignedIn() && (
        (request.auth.uid == resource.data.usuarioId) || 
        (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'])
      );
      
      allow update, delete: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
