rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DEPLOY TRIGGER: Adicionando permissões para fretes, cupons e pedidos.
     * Versão: 1.0.4
     */

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Verifica se o UID do usuário existe na coleção de administradores
      return isSignedIn() && exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE COLEÇÃO ---

    // Papéis administrativos
    match /roles_administrador/{usuarioId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    // Perfis de usuários
    match /usuarios/{usuarioId} {
      allow get, list: if isOwner(usuarioId) || isAdmin();
      allow create: if isOwner(usuarioId);
      allow update: if (isOwner(usuarioId) || isAdmin());
      allow delete: if isAdmin();
    }

    // Pedidos (Coleção Raiz)
    match /pedidos/{pedidoId} {
      // Qualquer um pode criar um pedido (necessário para o fluxo de WhatsApp)
      allow create: if true;
      // Apenas admin pode listar e ver detalhes de todos os pedidos
      allow read, update, delete: if isAdmin();
    }

    // Fretes e Cupons (Leitura pública para cálculo no checkout, escrita apenas admin)
    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Coleções do Catálogo e Configurações
    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{produtoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{promocaoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if true; // Liberado para prototipagem da Home
    }
  }
}