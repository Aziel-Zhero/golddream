
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado tem papel de administrador.
    // Para evitar recursão, usamos uma verificação direta.
    // Ao acessar o documento do próprio usuário autenticado (request.auth.uid),
    // a regra de leitura do documento de usuário deve permitir sem chamar isAdmin novamente.
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{usuarioId} {
      // O segredo para evitar a recursão infinita no isAdmin() é permitir que o usuário
      // leia seu próprio documento sem depender de uma chamada recursiva a isAdmin().
      // O curto-circuito do OR (||) garante que se for o dono, a verificação para por ali.
      allow read: if isSignedIn() && (request.auth.uid == usuarioId || isAdmin());
      allow list, update: if isSignedIn() && (request.auth.uid == usuarioId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == usuarioId;
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.usuarioId == request.auth.uid
      );
      
      allow get: if isSignedIn() && (
        isAdmin() || 
        resource.data.usuarioId == request.auth.uid
      );
      
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
