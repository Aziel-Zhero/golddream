rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * Gold Dream Multimarcas - Regras de Segurança
     * Versão: 1.0.6 - Correção de permissões de cadastro
     */

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE COLEÇÃO ---

    match /roles_administrador/{usuarioId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    match /usuarios/{usuarioId} {
      // Permite que o usuário crie seu próprio documento de perfil após se autenticar
      allow create: if isSignedIn() && request.auth.uid == usuarioId;
      allow get, list, update: if isOwner(usuarioId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      allow read, update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{produtoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{promocaoId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}