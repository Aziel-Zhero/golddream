
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica papel sem recursão chamando o documento de forma direta e protegida
    function hasRole(uid, roles) {
      return get(/databases/$(database)/documents/usuarios/$(uid)).data.papel in roles;
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{uid} {
      // Permite ler o próprio perfil sem checar isAdmin (evita recursão)
      // Admins podem ler qualquer perfil
      allow read: if isSignedIn() && (request.auth.uid == uid || hasRole(request.auth.uid, ['admin', 'administrador']));
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || hasRole(request.auth.uid, ['admin', 'administrador']));
      allow list, delete: if isSignedIn() && hasRole(request.auth.uid, ['admin', 'administrador']);
    }

    match /pedidos/{pedidoId} {
      // Qualquer usuário logado pode criar pedidos
      allow create: if isSignedIn();
      
      // Regra de leitura e listagem:
      // Admins podem ver tudo. Clientes podem ver apenas seus próprios documentos.
      allow read, list: if isSignedIn() && (
        hasRole(request.auth.uid, ['admin', 'administrador']) || 
        (resource != null && resource.data.usuarioId == request.auth.uid) ||
        (resource == null) // Permite que a query seja avaliada pelo Firestore
      );
      
      allow update, delete: if isSignedIn() && hasRole(request.auth.uid, ['admin', 'administrador']);
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(request.auth.uid, ['admin', 'administrador']);
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(request.auth.uid, ['admin', 'administrador']);
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(request.auth.uid, ['admin', 'administrador']);
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(request.auth.uid, ['admin', 'administrador']);
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(request.auth.uid, ['admin', 'administrador']);
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isSignedIn() && hasRole(request.auth.uid, ['admin', 'administrador']);
    }
  }
}
