
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && (
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador']
      );
    }

    // Configurações Gerais
    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Usuários
    match /usuarios/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isSignedIn() && request.auth.uid == userId;
      allow update: if isOwner(userId) || isAdmin();

      match /itens_elegiveis_avaliacao/{itemId} {
        allow read: if isOwner(userId);
        allow write: if isAdmin();
      }

      match /produtos_avaliados/{productId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
      }
    }

    // Produtos
    match /produtos/{productId} {
      allow read: if true;
      allow write: if isAdmin();

      match /avaliacoes/{reviewId} {
        allow read: if true;
        // Só cria se for o dono, se o item estiver na lista de elegíveis e não tiver sido avaliado
        allow create: if isSignedIn() 
          && request.resource.data.userId == request.auth.uid
          && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid)/itens_elegiveis_avaliacao/$(request.resource.data.productId + "_" + request.resource.data.orderId));
        allow delete: if isAdmin();
      }
    }

    // Pedidos
    match /pedidos/{orderId} {
      allow read: if isSignedIn() && (resource.data.usuarioId == request.auth.uid || isAdmin());
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }

    // Fretes, Cupons, Promoções, Suporte
    match /fretes/{id} { allow read: if true; allow write: if isAdmin(); }
    match /cupons/{id} { allow read: if isSignedIn(); allow write: if isAdmin(); }
    match /promocoes/{id} { allow read: if true; allow write: if isAdmin(); }
    match /suporte/{id} { allow read: if true; allow write: if isAdmin(); }
  }
}
