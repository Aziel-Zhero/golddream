
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é admin sem recursão
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador', 'admin_vogue'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{uid} {
      // Regra fundamental: Dono lê sempre sem chamar isAdmin para evitar recursão
      allow read: if isSignedIn() && (
        request.auth.uid == uid || isAdmin()
      );
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Permite criar pedido se estiver logado
      allow create: if isSignedIn();
      
      // Regra de leitura/listagem:
      // Para listagem (queries), o Firestore exige que a regra cubra o filtro aplicado no código.
      // O filtro 'usuarioId == uid' é validado aqui.
      allow read, list: if isSignedIn() && (
        (resource == null || resource.data.usuarioId == request.auth.uid) || 
        isAdmin()
      );
      
      allow update, delete: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
