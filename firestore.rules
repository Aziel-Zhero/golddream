rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DEPLOY TRIGGER: Atualização de regras para garantir acesso público ao catálogo e configurações.
     * Versão: 1.0.2
     */

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE COLEÇÃO ---

    // Papéis administrativos
    match /roles_administrador/{usuarioId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    // Perfis de usuários
    match /usuarios/{usuarioId} {
      allow get, list: if isOwner(usuarioId) || isAdmin();
      allow create: if isOwner(usuarioId) && request.resource.data.id == usuarioId;
      allow update: if (isOwner(usuarioId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      // Pedidos do usuário
      match /pedidos/{pedidoId} {
        allow get, list: if isOwner(usuarioId) || isAdmin();
        allow create: if isOwner(usuarioId);
        allow update, delete: if isAdmin();

        // Itens do pedido
        match /itensPedido/{itemPedidoId} {
          allow get, list: if isOwner(usuarioId) || isAdmin();
          allow create: if isOwner(usuarioId);
          allow update, delete: if isAdmin();
        }
      }
    }

    // Coleções Públicas (Leitura liberada para todos)
    match /categorias/{categoriaId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{produtoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{promocaoId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}