rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DEPLOY TRIGGER: Permissão de escrita liberada para coleções de catálogo e configurações para fins de prototipagem.
     * Versão: 1.0.3
     */

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Para o protótipo, vamos considerar que se o usuário está tentando acessar o admin, 
      // ou se a regra de escrita for true, ele pode prosseguir.
      return isSignedIn() && exists(/databases/$(database)/documents/roles_administrador/$(request.auth.uid));
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE COLEÇÃO ---

    // Papéis administrativos
    match /roles_administrador/{usuarioId} {
      allow get: if isSignedIn();
      allow list, create, update, delete: if isAdmin();
    }

    // Perfis de usuários
    match /usuarios/{usuarioId} {
      allow get, list: if isOwner(usuarioId) || isAdmin();
      allow create: if isOwner(usuarioId) && request.resource.data.id == usuarioId;
      allow update: if (isOwner(usuarioId) || isAdmin()) && request.resource.data.id == resource.data.id;
      allow delete: if isAdmin();

      // Pedidos do usuário
      match /pedidos/{pedidoId} {
        allow get, list: if isOwner(usuarioId) || isAdmin();
        allow create: if isOwner(usuarioId);
        allow update, delete: if isAdmin();
      }
    }

    // Coleções do Catálogo e Configurações (Acesso liberado para prototipagem rápida do painel admin)
    match /categorias/{categoriaId} {
      allow read, write: if true;
    }

    match /produtos/{produtoId} {
      allow read, write: if true;
    }

    match /promocoes/{promocaoId} {
      allow read, write: if true;
    }

    match /configuracoes/{configId} {
      allow read, write: if true;
    }
  }
}