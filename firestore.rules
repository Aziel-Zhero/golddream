
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário é admin verificando o campo papel no documento do usuário
    // Usamos get() de forma cautelosa para evitar recursão
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'];
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{usuarioId} {
      // Permite criar se estiver logado e for o próprio
      allow create: if isSignedIn() && request.auth.uid == usuarioId;
      // Permite ler se for o próprio (essencial para evitar erro no check de isAdmin)
      allow get: if isOwner(usuarioId) || isAdmin();
      // Outras operações apenas admin ou dono
      allow list, update: if isOwner(usuarioId) || isAdmin();
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Criação permitida para todos (checkout aberto)
      allow create: if true;
      
      // Listagem: Cliente vê apenas os seus. Admin vê todos.
      // Importante: O cliente deve usar query(..., where('usuarioId', '==', uid))
      allow list: if isAdmin() || (isSignedIn() && resource.data.usuarioId == request.auth.uid);
      
      // Get individual
      allow get: if isAdmin() || (isSignedIn() && resource.data.usuarioId == request.auth.uid);
      
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
