
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Função interna para obter o papel do usuário logado
    function getPapel() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel;
    }

    // Verifica se o usuário é administrador
    function isAdmin() {
      return isSignedIn() && getPapel() in ['admin', 'administrador'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{uid} {
      // PERMISSÃO CRÍTICA: O dono sempre lê seu próprio documento SEM chamar isAdmin() para evitar recursão
      allow read: if isSignedIn() && (request.auth.uid == uid || getPapel() in ['admin', 'administrador']);
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow list, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Criar pedido é livre para que visitantes possam comprar
      allow create: if true;
      
      // Regra de leitura/listagem:
      // 1. Administradores podem ler TUDO (necessário para o Painel Admin).
      // 2. Clientes podem ler apenas documentos onde o usuarioId coincide com seu UID.
      allow read, list: if isSignedIn() && (
        (get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador']) || 
        (resource.data.usuarioId == request.auth.uid)
      );
      
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
