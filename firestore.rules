
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Regra refinada para evitar recursão infinita no isAdmin()
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{usuarioId} {
      // PERMITIR que o usuário leia seu próprio perfil SEM chamar isAdmin() para quebrar a recursão
      allow read: if isSignedIn() && (request.auth.uid == usuarioId || 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador']);
      
      allow create: if isSignedIn();
      allow update: if isSignedIn() && (request.auth.uid == usuarioId || isAdmin());
      allow list, delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      allow create: if true;
      allow read, list: if isSignedIn() && (
        isAdmin() || 
        (resource.data.usuarioId == request.auth.uid)
      );
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
