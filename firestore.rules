
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- FUNÇÕES AUXILIARES ---

    function isSignedIn() {
      return request.auth != null;
    }

    // Verifica se o usuário logado tem papel de administrador
    // Usamos uma verificação direta para evitar loops de recursão
    function isAdmin() {
      return isSignedIn() && 
        get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.papel in ['admin', 'administrador'];
    }

    // --- REGRAS DE COLEÇÃO ---

    match /usuarios/{usuarioId} {
      // O próprio usuário pode ler seu perfil. Admins também podem ler perfis de terceiros.
      // Importante: a condição do dono vem primeiro para evitar chamadas de get() desnecessárias
      allow get: if isSignedIn() && (request.auth.uid == usuarioId || isAdmin());
      allow list, update: if isSignedIn() && (request.auth.uid == usuarioId || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == usuarioId;
      allow delete: if isAdmin();
    }

    match /pedidos/{pedidoId} {
      // Criação aberta para checkout rápido, mas vinculada ao UID se logado
      allow create: if true;
      
      // Listagem: Admin vê tudo. Cliente vê apenas os dele.
      allow list: if isSignedIn() && (
        isAdmin() || 
        resource.data.usuarioId == request.auth.uid
      );
      
      // Leitura individual segue a mesma lógica
      allow get: if isSignedIn() && (
        isAdmin() || 
        resource.data.usuarioId == request.auth.uid
      );
      
      // Apenas admin altera ou deleta pedidos
      allow update, delete: if isAdmin();
    }

    match /fretes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /cupons/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /produtos/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /configuracoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promocoes/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /suporte/{slug} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
